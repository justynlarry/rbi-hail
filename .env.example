# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# PostgreSQL (must match between docker-compose.yml and the app)
POSTGRES_USER=haildb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=haildb

# RentCast API
RENTCAST_API_KEY=

# Gmail SMTP (use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional tuning
# API_WORKERS=5             # parallel RentCast fetch threads (default: 5)
# REPORT_RETENTION_DAYS=90  # days to keep PDF reports on disk (default: 90)
